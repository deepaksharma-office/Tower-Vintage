{{ 'content-over-media.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

{% capture children %}
  {% content_for 'blocks' %}
{% endcapture %}
<div class="section-background color-{{ section.settings.color_scheme }}"></div>
<div
  class="section section--{{ section.settings.section_width }} color-{{ section.settings.color_scheme }}"
  data-testid="ui-test-section"

  {% if request.visual_preview_mode %}
    data-shopify-visual-preview
  {% endif %}
>
  <div class="section-{{ section.id }}-padding">
    <div
      class="content-over-image-section"
      style="
        --desktop-count: {{ section.settings.desktop }};
        --mobile-count: {{ section.settings.mobile }};
        --rg: {{ section.settings.col }}px;
        --cg: {{ section.settings.row }}px;
      "
    >
      {{ children }}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Content Over Media",
  "settings": [
    {
      "type": "select",
      "id": "section_width",
      "label": "t:settings.width",
      "options": [
        {
          "value": "page-width",
          "label": "t:options.page"
        },
        {
          "value": "full-width",
          "label": "t:options.full"
        }
      ],
      "default": "page-width"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:settings.color_scheme",
      "default": "scheme-1"
    },
    {
      "type": "range",
      "id": "row",
      "label": "Row Gap",
      "min": 0,
      "max": 60,
      "default": 2,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "col",
      "label": "Column Gap",
      "min": 0,
      "max": 60,
      "default": 2,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "desktop",
      "label": "Desktop Count",
      "min": 1,
      "max": 5,
      "default": 2
    },
    {
      "type": "select",
      "id": "mobile",
      "label": "Mobile Count",
      "default": "1",
      "options": [
        {
          "label": "1",
          "value": "1"
        },
        {
          "label": "2",
          "value": "2"
        }
      ]
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Top",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 0
    }
  ],
  "blocks": [
    {
      "type": "block-content-over-media"
    }
  ],
  "presets": [
    {
      "name": "Content Over Media",
      "category": "Custom"
    }
  ]
}
{% endschema %}
